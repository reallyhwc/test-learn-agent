#!/bin/bash
# post-commit — 本地未推送提交达到 5 条时自动 push
# 激活方式: git config core.hooksPath githooks

# 检查是否配置了远程仓库
REMOTE=$(git remote -v 2>/dev/null | head -1 | awk '{print $1}')
if [ -z "$REMOTE" ]; then
    exit 0  # 无远程，跳过
fi

BRANCH=$(git branch --show-current)
if [ -z "$BRANCH" ] || [ "$BRANCH" = "HEAD" ]; then
    exit 0  # Detached HEAD，跳过
fi

# 检查 upstream 是否已设置
UPSTREAM=$(git rev-parse --abbrev-ref "$BRANCH"@{upstream} 2>/dev/null)
if [ -z "$UPSTREAM" ]; then
    if git ls-remote --heads "$REMOTE" "$BRANCH" 2>/dev/null | grep -q "$BRANCH"; then
        UNPUSHED=$(git rev-list --count "$REMOTE/$BRANCH".."$BRANCH" 2>/dev/null || echo "0")
    else
        # 新分支，统计所有提交
        UNPUSHED=$(git rev-list --count HEAD 2>/dev/null || echo "0")
    fi
else
    UNPUSHED=$(git rev-list --count "$UPSTREAM"..HEAD 2>/dev/null || echo "0")
fi

if [ "$UNPUSHED" -ge 5 ]; then
    echo ""
    echo ">>> 未推送提交已达 ${UNPUSHED} 条（阈值: 5），自动推送到 ${REMOTE}/${BRANCH}..."
    git push "$REMOTE" "$BRANCH"
    echo ""
fi

exit 0
