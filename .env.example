# ============================================
# Personal Finance Agent - LLM Configuration
# ============================================
# 使用说明：
#   1. 复制此文件:  cp .env.example config.properties
#   2. 编辑 config.properties，填入你的实际配置
#   3. config.properties 已在 .gitignore 中忽略，不会被提交到 git
#
# 支持的 LLM 提供商 (OpenAI 兼容 API):
#   DeepSeek:   base-url=https://api.deepseek.com             model=deepseek-chat
#   通义千问:    base-url=https://dashscope.aliyuncs.com/compatible-mode/v1  model=qwen-plus
#   OpenAI:     base-url=https://api.openai.com               model=gpt-4o
#   Groq:       base-url=https://api.groq.com/openai          model=llama-3.3-70b-versatile
#   Moonshot:   base-url=https://api.moonshot.cn              model=moonshot-v1-8k
#   SiliconFlow: base-url=https://api.siliconflow.cn          model=deepseek-ai/DeepSeek-V3
# ============================================

# LLM API Key (必填)
LLM_API_KEY=your-api-key-here

# LLM Base URL (必填) - OpenAI 兼容 API 地址
LLM_BASE_URL=https://api.deepseek.com

# LLM Model Name (必填) - 模型名称
LLM_MODEL=deepseek-chat
